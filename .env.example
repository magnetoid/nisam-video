NODE_ENV=development
PORT=5001

DATABASE_URL=postgres://user:password@host:5432/postgres
DB_SSL=1

REDIS_URL=redis://localhost:6379

SESSION_SECRET=change-me-to-a-long-random-string

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ALLOW_DEV_DEFAULT_ADMIN=0

PUBLIC_BASE_URL=http://localhost:5001
CRON_SECRET=change-me
PUBLIC_ERROR_LOGS_TOKEN=change-me

BLOB_READ_WRITE_TOKEN=
VERCEL_OIDC_TOKEN=

DISABLE_SCHEDULER=0
KV_DISABLE_BACKGROUND_TASKS=0
KV_DEBUG=0

HEALTH_PROBE_INTERVAL_MS=10000

SCRAPE_BATCH_SIZE=10
SCRAPE_DELAY_MS=300
SCRAPE_DELAY_MAX_MS=3000
INCREMENTAL_BATCH_SIZE=10

MIGRATION_SOURCE_DATABASE_URL=
MIGRATION_TARGET_DATABASE_URL=
MIGRATION_SOURCE_DB_SSL=1
MIGRATION_TARGET_DB_SSL=1

EXIT_ON_UNCAUGHT_EXCEPTION=0
VITE_DEV_MODULE_PATH=./vite-dev.js

SUPABASE_URL=
DB_URL=
SUPABASE_POSTGRES_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
