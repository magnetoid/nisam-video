NODE_ENV=development
PORT=5001

# ── Docker Compose Postgres ──────────────────────────────
# Used by docker-compose.yml to create the database
POSTGRES_USER=nisam
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=nisam_video

# ── Database Connection ──────────────────────────────────
# For docker-compose: postgres://nisam:password@pgbouncer:5432/nisam_video
# For external Supabase: postgres://user:password@host:5432/postgres
DATABASE_URL=postgres://nisam:change-me-strong-password@localhost:5432/nisam_video
DB_SSL=0
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=5

# ── Redis ────────────────────────────────────────────────
# For docker-compose: redis://redis:6379
# For external Redis: redis://user:password@host:6379
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ALLOW_DEV_DEFAULT_ADMIN=0

# ── Public URLs ──────────────────────────────────────────
PUBLIC_BASE_URL=http://localhost:5001
APP_PORT=3000

# ── Security ─────────────────────────────────────────────
CRON_SECRET=change-me
PUBLIC_ERROR_LOGS_TOKEN=change-me-at-least-32-chars

# ── Storage (Vercel Blob) ────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ── Scraper Settings ─────────────────────────────────────
DISABLE_SCHEDULER=0
SCRAPE_BATCH_SIZE=10
SCRAPE_DELAY_MS=300
SCRAPE_DELAY_MAX_MS=3000

# ── Health & Debug ───────────────────────────────────────
HEALTH_PROBE_INTERVAL_MS=10000
KV_DISABLE_BACKGROUND_TASKS=0
EXIT_ON_UNCAUGHT_EXCEPTION=0

# ── Migration (one-time, for moving from Supabase) ──────
# Set these when running scripts/migrate-database.sh
# SOURCE_DATABASE_URL=postgres://user:pass@supabase-host:5432/postgres
# TARGET_DATABASE_URL=postgres://nisam:pass@localhost:5432/nisam_video
